#include <iostream>
#include <cmath>
#include <stdexcept>
#include <string>
using namespace std;

class Money {
private:
    double amount;      // розмір суми
    string currency;    // код валюти (USD, EUR, UAH ...)
    double rate;        // курс щодо долара (1 USD = rate одиниць валюти)
public:
    // Конструктор за замовчуванням
    Money() : amount(0.0), currency("USD"), rate(1.0) {}

    // Параметричний конструктор
    Money(double a, const string& cur, double r) {
        if (a < 0) throw invalid_argument("Amount cannot be negative");
        if (r <= 0) throw invalid_argument("Rate must be positive");
        amount = a; currency = cur; rate = r;
    }

    // Копіюючий конструктор
    Money(const Money& m) : amount(m.amount), currency(m.currency), rate(m.rate) {}

    // Конструктор переміщення
    Money(Money&& m) noexcept : amount(m.amount), currency(m.currency), rate(m.rate)
    { m.amount = 0.0; }

    // operator= копіюючий
    Money& operator=(const Money& m) {
        if (this == &m) return *this;
        amount = m.amount; currency = m.currency; rate = m.rate;
        return *this;
    }

    // operator= переміщуючий
    Money& operator=(Money&& m) noexcept {
        if (this == &m) return *this;
        amount = m.amount; currency = m.currency; rate = m.rate;
        m.amount = 0.0;
        return *this;
    }

    // operator[] — 0: amount, 1: rate
    double operator[](int i) const {
        if (i == 0) return amount;
        if (i == 1) return rate;
        throw out_of_range("Index must be 0 or 1");
    }

    // operator() — сума в доларах
    double operator()() const {
        return amount / rate;
    }

    // Перетворення типу до double — сума в доларах
    operator double() const {
        return amount / rate;
    }

    // operator== та !=  (порівнюємо суми в доларах)
    bool operator==(const Money& m) const {
        return fabs((double)*this - (double)m) < 1e-9;
    }
    bool operator!=(const Money& m) const {
        return !(*this == m);
    }

    // operator< та > (за сумою в доларах)
    bool operator<(const Money& m) const { return (double)*this < (double)m; }
    bool operator>(const Money& m) const { return m < *this; }

    // Додавання двох грошових сум (результат у валюті лівого операнда)
    Money operator+(const Money& m) const {
        double totalUSD = (double)*this + (double)m;
        return Money(totalUSD * rate, currency, rate);
    }

    // Різниця двох грошових сум
    Money operator-(const Money& m) const {
        double diffUSD = (double)*this - (double)m;
        if (diffUSD < 0) throw invalid_argument("Result would be negative");
        return Money(diffUSD * rate, currency, rate);
    }

    // Додавання числа до суми
    Money operator+(double val) const {
        if (amount + val < 0) throw invalid_argument("Result would be negative");
        return Money(amount + val, currency, rate);
    }

    // Віднімання числа від суми
    Money operator-(double val) const {
        if (amount - val < 0) throw invalid_argument("Result would be negative");
        return Money(amount - val, currency, rate);
    }

    // Число + грошова сума (дружня)
    friend Money operator+(double val, const Money& m) {
        return m + val;
    }

    // Виведення на консоль
    friend ostream& operator<<(ostream& out, const Money& m) {
        out << m.amount << " " << m.currency
            << " (rate: 1 USD = " << m.rate << " " << m.currency << ")";
        return out;
    }

    // Введення з консолі
    friend istream& operator>>(istream& in, Money& m) {
        double a, r; string c;
        in >> a >> c >> r;
        if (a < 0) throw invalid_argument("Amount cannot be negative");
        if (r <= 0) throw invalid_argument("Rate must be positive");
        m.amount = a; m.currency = c; m.rate = r;
        return in;
    }
};

int main() {
    // Конструктор за замовчуванням
    Money m1;
    cout << "m1 (default): " << m1 << endl;

    // Параметричний конструктор
    Money m2(1000.0, "UAH", 41.5);
    cout << "m2 (1000 UAH): " << m2 << endl;

    Money m3(50.0, "USD", 1.0);
    cout << "m3 (50 USD):   " << m3 << endl;

    // Копіюючий конструктор
    Money m4(m2);
    cout << "m4 (copy m2):  " << m4 << endl;

    // Конструктор переміщення
    Money m5(Money(200.0, "EUR", 1.08));
    cout << "m5 (moved EUR):" << m5 << endl;

    // operator=
    Money m6; m6 = m3;
    cout << "m6 (= m3):     " << m6 << endl;

    // operator[]
    cout << "\nm2[0] amount: " << m2[0] << endl;
    cout << "m2[1] rate:   " << m2[1] << endl;

    // operator() — сума в доларах
    cout << "m2 in USD via (): " << m2() << endl;

    // Перетворення типу double
    double usd = (double)m2;
    cout << "m2 in USD cast:   " << usd << endl;

    // operator== та !=
    cout << "\nm2 == m4: " << (m2 == m4 ? "true" : "false") << endl;
    cout << "m2 != m3: " << (m2 != m3 ? "true" : "false") << endl;

    // operator< та >
    cout << "m2 < m3:  " << (m2 < m3  ? "true" : "false") << endl;
    cout << "m3 > m2:  " << (m3 > m2  ? "true" : "false") << endl;

    // Додавання двох сум
    Money sum = m2 + m3;
    cout << "\nm2 + m3: " << sum << endl;

    // Різниця двох сум
    Money diff = m3 - Money(10.0, "USD", 1.0);
    cout << "m3 - 10USD: " << diff << endl;

    // Додавання/віднімання числа
    cout << "m2 + 500: " << (m2 + 500.0) << endl;
    cout << "m2 - 200: " << (m2 - 200.0) << endl;

    // operator>>
    cout << "\nEnter money (amount currency rate): ";
    Money m7; cin >> m7;
    cout << "You entered: " << m7 << endl;
    cout << "In USD: " << m7() << endl;

    return 0;
}
